# Django Settings
SECRET_KEY=your-super-secret-key-here-change-this
ENV=prod
ADMIN_EMAIL=admin@yourdomain.com

# Database Configuration
POSTGRES_DB=debate_db
POSTGRES_USER=debate_user
POSTGRES_PASSWORD=your-db-password

# Email Configuration
# Delivery backend used by django-post-office when sending queued mail.
# For AWS SES via HTTP (recommended for DigitalOcean/VPS that block SMTP ports):
EMAIL_BACKEND=django_ses.SESBackend
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_SES_REGION_NAME=us-east-1 # Optional, default is us-east-1
# AWS_SES_REGION_ENDPOINT=email.us-east-1.amazonaws.com  # Optional, derived from region

# For traditional SMTP (e.g., Gmail):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-email-password

# Frontend URL (for email links)
FRONTEND_URL=https://your-domain.com

# Allowed Hosts (comma-separated list)
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# CORS Origins (comma-separated list)
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# CSRF Trusted Origins (comma-separated list)
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
