# Django Settings
SECRET_KEY=your-super-secret-key-here-change-this
ENV=prod
ADMIN_EMAIL=admin@yourdomain.com

# Database Configuration
POSTGRES_DB=debate_db
POSTGRES_USER=debate_user
POSTGRES_PASSWORD=your-db-password

# Email Configuration
# Delivery backend used by django-post-office when sending queued mail.
# Default is Anymail's Resend backend. Set this only if you later swap providers.
# POST_OFFICE_DELIVERY_BACKEND=anymail.backends.resend.EmailBackend
DEFAULT_FROM_EMAIL="OpenNoesis <noreply@opennoesis.com>"
RESEND_API_KEY=your-resend-api-key

# Frontend URL (for email links)
FRONTEND_URL=https://your-domain.com

# Cloudflare R2 image storage
R2_ACCOUNT_ID=your-r2-account-id
R2_BUCKET_NAME=your-r2-bucket
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Public bucket/custom-domain base URL used for image delivery, e.g.:
R2_PUBLIC_BASE_URL=https://media.your-domain.com

# OpenAI (AI debates)
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-5-mini
# OPENAI_MODERATION_MODEL=omni-moderation-latest
# OPENAI_TIMEOUT_SECONDS=15
# DEBATE_IMAGE_MAX_BYTES=10485760
# AI_CONTEXT_COMPACTION_TRIGGER_TOKENS=8192
# AI_MAX_OUTPUT_TOKENS=512
# AI_BOT_USERNAME=opennoesis_ai
# AI_BOT_EMAIL=ai@opennoesis.local

# Allowed Hosts (comma-separated list)
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# CORS Origins (comma-separated list)
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# CSRF Trusted Origins (comma-separated list)
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
