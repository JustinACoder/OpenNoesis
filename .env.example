## Build Environment Variables
# If ran in prod (docker-compose.build.yml for prod), the default value
# for NEXT_PUBLIC_API_URL will be empty, representing that fetch calls
# will be relative to the current domain (ideal when using a reverse proxy)
# If ran in dev (docker-compose.dev.yml for dev), the default value
# for NEXT_PUBLIC_API_URL will be http://localhost:8000, representing that
# fetch calls will be made to the backend running on localhost port 8000
# unless you override it here.
# Therefore, in normal usage, you should not modify this value here.
# Format: http(s)://domain:port or <empty> for relative
#NEXT_PUBLIC_API_URL=

# WebSocket URL for real-time connections
# If ran in prod, the default value will be empty, and you must set this
# to your production WebSocket URL (e.g., wss://yourdomain.com/ws/)
# If ran in dev, the default value will be ws://localhost:8000/ws/
# Format: ws(s)://domain:port/ws/
#NEXT_PUBLIC_WS_URL=

# Public Discord invite used by frontend navigation/footer links.
# This is injected at frontend build time.
#NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/cMwUJkdTJ4

# Shared backend Prometheus multiprocess directory.
# Keep this consistent across backend startup paths.
#PROMETHEUS_MULTIPROC_DIR=/tmp/django_prometheus_multiproc

# Grafana Cloud Prometheus remote_write credentials for Alloy.
# URL example: https://prometheus-prod-XX-XXX.grafana.net/api/prom/push
#GRAFANA_CLOUD_PROMETHEUS_URL=
# Username is your Grafana Cloud metrics instance ID.
#GRAFANA_CLOUD_PROMETHEUS_USERNAME=
# Password is a Grafana Cloud API token with metrics:write.
#GRAFANA_CLOUD_PROMETHEUS_PASSWORD=
